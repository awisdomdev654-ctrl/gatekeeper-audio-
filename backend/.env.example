# MongoDB (audit trail + stem metadata)
MONGODB_URI=mongodb://127.0.0.1:27017/gatekeeper

# AWS S3 — SSE-S3 AES-256 is applied on upload; presigned GET expires in 10 minutes in code
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=your-gatekeeper-bucket

# Set true to return mock presigned URLs without calling AWS (local dev)
GATEKEEPER_MOCK_CLOUD=false
